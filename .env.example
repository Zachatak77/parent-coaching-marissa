# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://reimagineparenting.co

# Email (Resend)
RESEND_API_KEY=re_your-key

# Calendly
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/event-type

# Google Calendar Integration
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_CALENDAR_CHANNEL_SECRET=some-random-secret-32-chars

# Gemini AI (blog post generation)
GEMINI_API_KEY=

# Blog automation (n8n / external HTTP clients)
# Generate: openssl rand -hex 32
BLOG_API_KEY=
# Supabase user UUID that automated posts are attributed to (must exist in profiles table)
BLOG_AUTOMATION_AUTHOR_ID=
